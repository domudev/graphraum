<figure class="home-graph not-content">
	<div
		id="home-graph-canvas"
		class="home-graph-canvas"
		role="img"
		aria-label="An interactive network rendered live by graphraum. Drag to pan, scroll to zoom, or select a node."
	></div>
	<figcaption>
		<span><i aria-hidden="true"></i> Rendered live by graphraum</span>
		<span>Drag to pan · scroll to zoom · select a node</span>
	</figcaption>
</figure>

<script>
	import { Graphraum, type GraphraumData } from "@domudev/graphraum";

	const container = document.querySelector<HTMLElement>("#home-graph-canvas");
	if (!container) throw new Error("Homepage graph container was not found.");

	const data = {
		nodes: [
			{ id: "node-0", position: { x: -410, y: -40 }, size: 16 },
			{ id: "node-1", position: { x: -280, y: 105 }, size: 22 },
			{ id: "node-2", position: { x: -250, y: -125 }, size: 13 },
			{ id: "node-3", position: { x: -95, y: 30 }, size: 28 },
			{ id: "node-4", position: { x: 45, y: 155 }, size: 13 },
			{ id: "node-5", position: { x: 85, y: -120 }, size: 19 },
			{ id: "node-6", position: { x: 205, y: 65 }, size: 24 },
			{ id: "node-7", position: { x: 335, y: -105 }, size: 15 },
			{ id: "node-8", position: { x: 375, y: 135 }, size: 18 },
			{ id: "node-9", position: { x: 500, y: 0 }, size: 23 },
		],
		edges: [
			[0, 1], [1, 3], [3, 4], [4, 6], [6, 8], [8, 9],
			[0, 2], [2, 3], [3, 5], [5, 6], [6, 7], [7, 9],
			[1, 2], [4, 5], [8, 7], [3, 6], [2, 5], [5, 7],
		].map(([source, target], index) => ({
			id: `edge-${index}`,
			source: `node-${source}`,
			target: `node-${target}`,
		})),
	} satisfies GraphraumData;

	const graph = new Graphraum(container, {
		maxPixelRatio: 1,
		theme: {
			background: "#040f0f",
			edge: "#226f54",
			node: "#3f7b65",
			selectedNode: "#fcfffc",
		},
	});
	graph.setData(data);
	graph.setSelection(["node-6"]);

	container.addEventListener("click", (event) => {
		const nodeId = graph.pick(event.clientX, event.clientY);
		graph.setSelection(nodeId ? [nodeId] : []);
	});

	window.addEventListener("pagehide", () => graph.destroy(), { once: true });
</script>

<style>
	.home-graph {
		background: #040f0f;
		border: 1px solid #226f54;
		border-radius: 1rem;
		margin: 1rem auto 4rem;
		max-width: 72rem;
		overflow: hidden;
	}

	.home-graph-canvas {
		height: clamp(20rem, 42vw, 32rem);
		touch-action: none;
		width: 100%;
	}

	figcaption {
		align-items: center;
		border-top: 1px solid #17372d;
		color: #b8c9c1;
		display: flex;
		flex-wrap: wrap;
		font-size: 0.72rem;
		gap: 0.75rem 1.25rem;
		justify-content: space-between;
		padding: 0.8rem 1rem;
	}

	figcaption span:first-child {
		align-items: center;
		display: flex;
		gap: 0.45rem;
	}

	figcaption i {
		background: #73c7a5;
		border-radius: 50%;
		display: inline-block;
		height: 0.55rem;
		width: 0.55rem;
	}

	@media (max-width: 40rem) {
		.home-graph {
			border-radius: 0.7rem;
		}

		.home-graph-canvas {
			height: 19rem;
		}
	}
</style>
