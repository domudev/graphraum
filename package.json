{
	"name": "@domudev/graphraum",
	"version": "0.0.0",
	"description": "An opinionated WebGL engine for interactive graphs in 2D and 3D",
	"type": "module",
	"license": "Apache-2.0",
	"packageManager": "bun@1.3.1",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/domudev/graphraum.git"
	},
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsdown",
		"check": "biome check . && tsc --noEmit",
		"dev": "vite examples/benchmark",
		"test": "vitest run"
	},
	"engines": {
		"bun": ">=1.2.0"
	},
	"dependencies": {
		"three": "^0.185.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.5",
		"@types/three": "^0.185.1",
		"tsdown": "^0.22.13",
		"typescript": "^6.0.3",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	}
}
