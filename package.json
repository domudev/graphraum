{
	"name": "@domudev/graphraum",
	"version": "0.2.2",
	"description": "An opinionated WebGL engine for interactive graphs in 2D and 3D",
	"type": "module",
	"license": "Apache-2.0",
	"packageManager": "bun@1.3.1",
	"publishConfig": {
		"access": "public",
		"registry": "https://npm.pkg.github.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/domudev/graphraum.git"
	},
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsdown",
		"check": "biome check . && tsc --noEmit",
		"dev": "vite examples/benchmark",
		"docs:build": "bun run --cwd docs build",
		"docs:check": "bun run --cwd docs check",
		"docs:dev": "bun run --cwd docs dev",
		"docs:test": "bun run --cwd docs test",
		"prepack": "bun run build",
		"release": "semantic-release",
		"test": "vitest run --dir src"
	},
	"engines": {
		"bun": ">=1.2.0"
	},
	"dependencies": {
		"three": "^0.185.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.5",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@types/three": "^0.185.1",
		"semantic-release": "^25.0.8",
		"tsdown": "^0.22.13",
		"typescript": "^6.0.3",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	}
}
